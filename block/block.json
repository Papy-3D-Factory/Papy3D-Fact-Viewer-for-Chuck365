{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "chuck365/viewer",
    "title": "Chuck365 Fact Viewer",
    "category": "widgets",
    "icon": "superhero",
    "description": "Affiche un fait de Chuck Norris chaque jour.",
    "textdomain": "chuck365-fact-viewer",
    "version": "2.0.3",
    "supports": {
        "html": false,
        "anchor": true
    },
    "attributes": {
        "borderColor":   { "type": "string" },
        "bgColor":       { "type": "string" },
        "textColor":     { "type": "string" },
        "title":         { "type": "string" },
        "showCopyright": { "type": "boolean", "default": true }
    },
    "style": "chuck365-style",
    "editorScript": "chuck365-editor-script"
}